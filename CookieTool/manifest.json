{
  "manifest_version": 3,
  "name": "Cookie Tool",
  "version": "0.0.1",
  "author": "wenterwang",
  "permissions": [
    "alarms",
    "cookies",
    "activeTab",
    "scripting",
	"webRequest"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Get Current Page Cookies",
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "popup.js"
  },
  "content_scripts": [
        {
            "matches": ["https://wangdian.sto.cn/index"],
            "js": ["popup.js"],
            "all_frames": true,
            "run_at": "document_start"
        }
    ]
}